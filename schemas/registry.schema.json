{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://awesome-codex-theme.dev/schemas/registry.schema.json",
  "title": "Awesome Codex Theme Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "standard", "generatedBy", "catalogRevision", "collections", "themes"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "standard": {
      "const": "act-theme-pack-v1"
    },
    "generatedBy": {
      "type": "string"
    },
    "catalogRevision": {
      "type": "integer",
      "minimum": 1
    },
    "collections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "order", "pairing", "name", "title", "description", "themeCount"]
      }
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "version",
          "collection",
          "pair",
          "variant",
          "rightsProfile",
          "name",
          "tagline",
          "description",
          "tags",
          "license",
          "provenance",
          "motion",
          "previews",
          "package",
          "exports"
        ],
        "properties": {
          "audience": {
            "enum": ["global", "en", "zh-CN"]
          },
          "featuredRank": {
            "type": "object",
            "additionalProperties": false,
            "required": ["en", "zh-CN"],
            "properties": {
              "en": {
                "type": "integer",
                "minimum": 0
              },
              "zh-CN": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "tagline": {
            "$ref": "#/$defs/localizedShort"
          },
          "previews": {
            "type": "object",
            "additionalProperties": false,
            "required": ["light", "dark"],
            "properties": {
              "light": {
                "$ref": "#/$defs/modeRecord"
              },
              "dark": {
                "$ref": "#/$defs/modeRecord"
              }
            }
          },
          "exports": {
            "type": "object",
            "additionalProperties": false,
            "required": ["codex-full-skin", "codex-native"],
            "properties": {
              "codex-full-skin": {
                "type": "object",
                "additionalProperties": false,
                "required": ["coverage", "format", "testedVersion", "delivery", "limitations"],
                "properties": {
                  "coverage": {
                    "const": "full-skin-v1"
                  },
                  "format": {
                    "const": "act-full-skin-v1"
                  },
                  "testedVersion": {
                    "type": "string",
                    "minLength": 1
                  },
                  "delivery": {
                    "const": "Awesome Codex Theme Manager"
                  },
                  "limitations": {
                    "type": "array",
                    "prefixItems": [
                      {
                        "const": "runtime-session"
                      },
                      {
                        "const": "no-layout-replacement"
                      }
                    ],
                    "items": false,
                    "minItems": 2,
                    "maxItems": 2
                  }
                }
              },
              "codex-native": {
                "type": "object",
                "additionalProperties": false,
                "required": ["coverage", "format", "testedVersion", "importPath", "limitations"],
                "properties": {
                  "coverage": {
                    "const": "native-theme-v1"
                  },
                  "format": {
                    "const": "codex-theme-v1"
                  },
                  "testedVersion": {
                    "type": "string",
                    "minLength": 1
                  },
                  "importPath": {
                    "const": "Settings > Appearance > Import"
                  },
                  "limitations": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1,
                    "items": {
                      "const": "background-image"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "localizedShort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "zh-CN"],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "zh-CN": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        }
      }
    },
    "modeRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview",
        "previewSha256",
        "assetSha256",
        "assetBytes",
        "fullSkin",
        "nativeTheme"
      ],
      "properties": {
        "preview": {
          "type": "string",
          "pattern": "^themes/[a-z0-9-]+/previews/(light|dark)\\.png$"
        },
        "previewSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "assetSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "assetBytes": {
          "type": "integer",
          "minimum": 1
        },
        "fullSkin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "asset", "sha256", "bytes", "art", "tokens", "testedVersion"],
          "properties": {
            "format": {
              "const": "act-full-skin-v1"
            },
            "asset": {
              "type": "string",
              "pattern": "^themes/[a-z0-9-]+/assets/background-(light|dark)\\.png$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 16777216
            },
            "art": {
              "type": "object",
              "additionalProperties": false,
              "required": ["focusX", "focusY", "safeArea", "taskMode"],
              "properties": {
                "focusX": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "focusY": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "safeArea": {
                  "enum": ["left", "right", "center", "none"]
                },
                "taskMode": {
                  "enum": ["ambient", "banner", "off"]
                }
              }
            },
            "tokens": {
              "type": "object",
              "additionalProperties": false,
              "required": ["background", "surface", "surfaceAlt", "text", "muted", "accent", "accentContrast", "border"],
              "properties": {
                "background": {
                  "$ref": "#/$defs/hex"
                },
                "surface": {
                  "$ref": "#/$defs/hex"
                },
                "surfaceAlt": {
                  "$ref": "#/$defs/hex"
                },
                "text": {
                  "$ref": "#/$defs/hex"
                },
                "muted": {
                  "$ref": "#/$defs/hex"
                },
                "accent": {
                  "$ref": "#/$defs/hex"
                },
                "accentContrast": {
                  "$ref": "#/$defs/hex"
                },
                "border": {
                  "$ref": "#/$defs/hex"
                }
              }
            },
            "testedVersion": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "nativeTheme": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "path", "sha256", "bytes", "testedVersion", "value"],
          "properties": {
            "format": {
              "const": "codex-theme-v1"
            },
            "path": {
              "type": "string",
              "pattern": "^packages/native/[a-z0-9-]+-(light|dark)\\.codex-theme\\.txt$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4096
            },
            "testedVersion": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "string",
              "pattern": "^codex-theme-v1:"
            }
          }
        },
        "capture": {
          "$ref": "#/$defs/captureRecord"
        }
      }
    },
    "captureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes",
        "width",
        "height",
        "assetSha256",
        "runtimeSha256",
        "markerVersion",
        "selectors",
        "appVersion",
        "packageFullName",
        "fixture",
        "modelLabel",
        "capturedAt"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^screenshots/codex-beta-[0-9.]+/[a-z0-9-]+-(light|dark)\\.png$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5242880
        },
        "width": {
          "const": 1440
        },
        "height": {
          "const": 810
        },
        "assetSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "runtimeSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "markerVersion": {
          "const": "act-full-skin-v1"
        },
        "selectors": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sidebar", "composer", "main"],
          "properties": {
            "sidebar": {
              "type": "boolean"
            },
            "composer": {
              "type": "boolean"
            },
            "main": {
              "const": true
            }
          }
        },
        "appVersion": {
          "type": "string",
          "minLength": 1
        },
        "packageFullName": {
          "type": "string",
          "pattern": "^OpenAI\\.CodexBeta_"
        },
        "fixture": {
          "const": "full-skin-home-v1"
        },
        "modelLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "hex": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    }
  }
}
