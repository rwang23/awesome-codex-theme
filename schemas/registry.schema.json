{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://awesome-codex-theme.dev/schemas/registry.schema.json",
  "title": "Awesome Codex Theme Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "standard", "generatedBy", "collections", "themes"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "standard": {
      "const": "act-theme-pack-v1"
    },
    "generatedBy": {
      "type": "string"
    },
    "collections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "order", "pairing", "name", "title", "description", "themeCount"]
      }
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "version",
          "collection",
          "pair",
          "variant",
          "rightsProfile",
          "name",
          "tagline",
          "description",
          "tags",
          "license",
          "provenance",
          "motion",
          "previews",
          "package",
          "exports"
        ],
        "properties": {
          "tagline": {
            "$ref": "#/$defs/localizedShort"
          },
          "previews": {
            "type": "object",
            "additionalProperties": false,
            "required": ["light", "dark"],
            "properties": {
              "light": {
                "$ref": "#/$defs/modeRecord"
              },
              "dark": {
                "$ref": "#/$defs/modeRecord"
              }
            }
          },
          "exports": {
            "type": "object",
            "additionalProperties": false,
            "required": ["codex-native"],
            "properties": {
              "codex-native": {
                "type": "object",
                "additionalProperties": false,
                "required": ["coverage", "format", "testedVersion", "importPath", "limitations"],
                "properties": {
                  "coverage": {
                    "const": "native-theme-v1"
                  },
                  "format": {
                    "const": "codex-theme-v1"
                  },
                  "testedVersion": {
                    "type": "string",
                    "minLength": 1
                  },
                  "importPath": {
                    "const": "Settings > Appearance > Import"
                  },
                  "limitations": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1,
                    "items": {
                      "const": "background-image"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "localizedShort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "zh-CN"],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "zh-CN": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        }
      }
    },
    "modeRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview",
        "previewSha256",
        "assetSha256",
        "assetBytes",
        "nativeTheme"
      ],
      "properties": {
        "preview": {
          "type": "string",
          "pattern": "^themes/[a-z0-9-]+/previews/(light|dark)\\.png$"
        },
        "previewSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "assetSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "assetBytes": {
          "type": "integer",
          "minimum": 1
        },
        "nativeTheme": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "path", "sha256", "bytes", "testedVersion", "value"],
          "properties": {
            "format": {
              "const": "codex-theme-v1"
            },
            "path": {
              "type": "string",
              "pattern": "^packages/native/[a-z0-9-]+-(light|dark)\\.codex-theme\\.txt$"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "bytes": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4096
            },
            "testedVersion": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "string",
              "pattern": "^codex-theme-v1:"
            }
          }
        },
        "capture": {
          "$ref": "#/$defs/captureRecord"
        }
      }
    },
    "captureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes",
        "width",
        "height",
        "nativeSha256",
        "readbackSha256",
        "canonicalizedByApp",
        "appVersion",
        "packageFullName",
        "fixture",
        "capturedAt"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^screenshots/codex-beta-[0-9.]+/[a-z0-9-]+-(light|dark)\\.png$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5242880
        },
        "width": {
          "const": 1440
        },
        "height": {
          "const": 810
        },
        "nativeSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "readbackSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "canonicalizedByApp": {
          "type": "boolean"
        },
        "appVersion": {
          "type": "string",
          "minLength": 1
        },
        "packageFullName": {
          "type": "string",
          "pattern": "^OpenAI\\.CodexBeta_"
        },
        "fixture": {
          "const": "settings-appearance-v1"
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
